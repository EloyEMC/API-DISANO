{
  "project": {
    "name": "API-DISANO",
    "description": "API REST FastAPI para catálogo eléctrico DISANO/FOSNOVA con autenticación, BC3 y PostgreSQL",
    "version": "2.1",
    "techStack": ["FastAPI", "PostgreSQL 15+", "Pydantic", "SQLAlchemy", "Gunicorn", "Nginx", "Redis"],
    "language": "python",
    "testFramework": "pytest",
    "testCoverageTarget": 80,
    "testCountTarget": 250,
    "docs": [
      "README.md",
      "docs/PROJECT.md",
      "docs/MIGRATION_PLAN.md",
      "docs/PATTERNS.md",
      "docs/ARCHITECTURE.md",
      "docs/SECURITY_MODEL.md",
      "app/GUIA_DESARROLLO.md",
      "app/routers/GUIA_ENDPOINTS.md",
      "app/security/GUIA_SEGURIDAD.md"
    ],
    "referenceProject": {
      "name": "BC3-Suite",
      "path": "/Users/eloymartinezcuesta/Documents/BC3-Suite",
      "description": "Proyecto referencia para patrones, arquitectura y normas"
    }
  },
  "conventions": {
    "codeStyle": {
      "language": "python",
      "formatter": "black",
      "formatterVersion": "23.12.1",
      "lineLength": 100,
      "linter": "flake8",
      "linterVersion": "6.1.0",
      "docstringStyle": "google",
      "docstyleVersion": "6.3.0"
    },
    "naming": {
      "variables": "snake_case",
      "functions": "snake_case",
      "classes": "PascalCase",
      "constants": "UPPER_CASE",
      "apiEndpoints": "kebab-case",
      "databaseTables": "lowercase",
      "databaseColumns": "lowercase"
    },
    "fileStructure": {
      "source": "app/",
      "tests": "tests/",
      "docs": "docs/",
      "infrastructure": "app/infrastructure/",
      "domain": "app/domain/",
      "api": "app/api/"
    },
    "apiVersioning": {
      "current": "v2",
      "deprecated": "v1",
      "deprecationDate": "TBD",
      "sunsetDate": "TBD"
    },
    "commitConvention": "conventional",
    "commitTypes": ["feat", "fix", "refactor", "docs", "test", "chore", "perf", "ci"]
  },
  "devCommands": {
    "start": "uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "startProd": "gunicorn --workers 4 --worker-class uvicorn.workers.UvicornWorker --bind 127.0.0.1:8000 wsgi:app",
    "test": "pytest -v",
    "testCoverage": "pytest --cov=app --cov-report=html --cov-report=term",
    "testWatch": "pytest-watch",
    "lint": "flake8 app/ tests/",
    "format": "black app/ tests/ --line-length=100",
    "formatCheck": "black --check app/ tests/ --line-length=100",
    "docstringCheck": "pydocstyle app/ tests/ --convention=google",
    "securityScan": "bandit -r app/ && safety check && pip-audit",
    "precommit": "pre-commit run --all-files",
    "typecheck": "mypy app/"
  },
  "qualityGates": {
    "testCoverageMin": 80,
    "flake8MaxLineLength": 100,
    "banditSeverity": "low",
    "banditConfidence": "medium",
    "pydocstyleConvention": "google"
  },
  "hotPaths": [
    "**/app/security/**",
    "**/app/api/**",
    "**/app/domain/**",
    "**/app/infrastructure/**",
    "**/app/config.py",
    "**/app/main.py",
    "**/app/middleware.py"
  ],
  "exclude": [
    "node_modules",
    ".git",
    "__pycache__",
    "*.pyc",
    ".venv",
    "venv",
    "database/",
    "*.db",
    "logs/",
    ".pytest_cache",
    ".coverage",
    "htmlcov/",
    "*.egg-info",
    ".mypy_cache",
    ".bandit",
    "dist/",
    "build/"
  ],
  "testing": {
    "framework": "pytest",
    "version": "7.4+",
    "plugins": ["pytest-cov", "pytest-mock", "pytest-asyncio", "pytest-watch"],
    "coverageTool": "pytest-cov",
    "coverageTarget": 80,
    "coverageReportFormats": ["html", "term", "xml"],
    "fixtures": {
      "client": "TestClient FastAPI",
      "db_session": "PostgreSQL test database",
      "auth_headers": "Valid API key headers",
      "admin_headers": "Valid admin API key headers"
    },
    "testStructure": {
      "unit": "tests/unit/",
      "integration": "tests/integration/",
      "factories": "tests/factories/",
      "conftest": "tests/conftest.py"
    },
    "patterns": {
      "aaa": "Arrange, Act, Assert",
      "useFactories": "No hardcoded test data",
      "mockExternalApis": "Never call real APIs"
    }
  },
  "security": {
    "enabled": true,
    "scanning": {
      "bandit": {
        "enabled": true,
        "version": "1.7.5+",
        "severity": "low",
        "confidence": "medium"
      },
      "safety": {
        "enabled": true,
        "version": "2.3.5+"
      },
      "pipAudit": {
        "enabled": true,
        "version": "2.5+"
      }
    },
    "authentication": {
      "method": "API Key",
      "headers": {
        "apiKey": "X-API-Key",
        "adminApiKey": "X-Admin-API-Key"
      },
      "twoFactor": {
        "enabled": true,
        "method": "OTP",
        "delivery": "email",
        "expiryMinutes": 10,
        "maxAttempts": 3
      }
    },
    "rateLimiting": {
      "enabled": true,
      "backend": "redis",
      "perClient": 30,
      "perClientWindow": "1 minute",
      "global": 1000,
      "globalWindow": "1 minute",
      "burst": 10
    },
    "headers": {
      "hsts": {
        "enabled": true,
        "maxAge": 31536000,
        "includeSubdomains": true,
        "preload": true
      },
      "xContentTypeOptions": "nosniff",
      "xFrameOptions": "DENY",
      "xXssProtection": "1; mode=block",
      "referrerPolicy": "no-referrer",
      "contentSecurityPolicy": "default-src 'self'"
    }
  },
  "database": {
    "development": {
      "type": "sqlite",
      "path": "database/tarifa_disano.db"
    },
    "production": {
      "type": "postgresql",
      "version": "15+",
      "host": "localhost",
      "port": 5432,
      "name": "api_disano_db",
      "user": "api_disano_user",
      "poolSize": 20,
      "maxOverflow": 10
    },
    "testing": {
      "type": "postgresql",
      "name": "api_disano_test_db",
      "isolationLevel": "autocommit"
    }
  },
  "deployment": {
    "server": {
      "type": "VPS",
      "provider": "Hetzner",
      "ip": "46.62.227.64",
      "os": "Ubuntu 22.04 LTS"
    },
    "webServer": {
      "type": "nginx",
      "version": "1.24+",
      "ssl": {
        "enabled": true,
        "provider": "letsencrypt",
        "domains": ["api.eloymartinezcuesta.com"]
      }
    },
    "appServer": {
      "type": "gunicorn",
      "version": "21.2+",
      "workers": 4,
      "workerClass": "uvicorn.workers.UvicornWorker",
      "bind": "127.0.0.1:8000",
      "timeout": 30
    },
    "processManager": {
      "type": "systemd",
      "serviceFile": "/etc/systemd/system/api-disano.service"
    },
    "monitoring": {
      "logs": {
        "access": "/var/log/api-disano/access.log",
        "error": "/var/log/api-disano/error.log",
        "security": "/var/log/api-disano/security.log"
      },
      "healthCheck": "/health",
      "metrics": {
        "requests": true,
        "errors": true,
        "rateLimits": true
      }
    }
  },
  "cicd": {
    "platform": "GitHub Actions",
    "on": ["push", "pull_request"],
    "jobs": [
      {
        "name": "Tests",
        "steps": ["setup-python", "install-deps", "pytest", "coverage-check"]
      },
      {
        "name": "Linting",
        "steps": ["black-check", "flake8", "pydocstyle"]
      },
      {
        "name": "Security Scanning",
        "steps": ["bandit", "safety", "pip-audit"]
      }
    ]
  },
  "skills": {
    "recommended": [
      "pytest",
      "cognitive-doc-design"
    ],
    "projectSpecific": {
      "python": "/Users/eloymartinezcuesta/.config/opencode/skills/pytest/SKILL.md"
    },
    "bc3SuitePatterns": {
      "hexagonalArchitecture": "docs/PATTERNS.md",
      "securityModel": "docs/SECURITY_MODEL.md",
      "architecture": "docs/ARCHITECTURE.md"
    }
  },
  "referenceStandards": {
    "project": "BC3-Suite",
    "path": "/Users/eloymartinezcuesta/Documents/BC3-Suite",
    "copyFiles": [
      ".pre-commit-config.yaml",
      "docs/PATTERNS.md",
      "docs/ARCHITECTURE.md",
      "docs/SECURITY_MODEL.md"
    ],
    "adoptPatterns": [
      "Arquitectura Hexagonal",
      "Repository Pattern",
      "Service Layer",
      "Domain Models",
      "AAA Testing",
      "Pre-commit Hooks",
      "CI/CD GitHub Actions",
      "3-tier RBAC",
      "Security Scanning"
    ]
  },
  "llmProvider": {
    "name": "z.ai",
    "config": {
      "enabled": true,
      "models": {
        "default": "zai-sonnet",
        "fast": "zai-haiku",
        "code": "zai-sonnet",
        "reasoning": "zai-opus"
      },
      "features": {
        "streaming": true,
        "functionCalling": true,
        "jsonMode": true,
        "temperature": 0.7
      }
    }
  }
}